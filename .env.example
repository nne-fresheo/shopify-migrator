# ── Required ─────────────────────────────────────────────────────────────────

SOURCE_SHOP_DOMAIN=my-store.myshopify.com
DEST_SHOP_DOMAIN=new-store.myshopify.com

# ── Authentication (choose one method per store) ──────────────────────────────
#
# Option A — Static access token (custom app token from Shopify admin)
SOURCE_ACCESS_TOKEN=
DEST_ACCESS_TOKEN=
#
# Option B — OAuth client credentials (client_id + client_secret from Partners dashboard)
# A short-lived token is fetched automatically on startup.
# If both options are set, client credentials take priority.
SOURCE_CLIENT_ID=
SOURCE_CLIENT_SECRET=
DEST_CLIENT_ID=
DEST_CLIENT_SECRET=

# ── Optional (defaults shown) ────────────────────────────────────────────────

API_VERSION=2024-01
DATA_DIR=./data
LOG_LEVEL=INFO

REST_BUCKET_SIZE=40
REST_REFILL_RATE=2
GRAPHQL_MAX_COST=1000
GRAPHQL_RESTORE_RATE=50
GRAPHQL_COST_THRESHOLD=200
MAX_RETRIES=5

# ── Django-to-Shopify meal sync (sync-meals subcommand) ──────────────────────
#
# Required for `python -m migration sync-meals`. Connect to the Fresheo Django
# Postgres DB to pull meals and push them as Shopify products.
DJANGO_DATABASE_URL=postgres://user:pass@host:5432/fresheo
#
# Optional. Used to build full image URLs from Meal.picture (relative path) when
# Meal.meal_image (full URL) is empty. Example for the prod S3 bucket:
# DJANGO_MEDIA_URL=https://fresheo-prod.s3.amazonaws.com/media/
DJANGO_MEDIA_URL=
#
# External HTML template rendered into product body_html. Edit freely.
DESCRIPTION_TEMPLATE=./templates/product_description.html.j2
#
# Locale tag used by tr_str() to extract translated text from <fr>...</fr> blocks.
MEAL_LOCALE=fr
