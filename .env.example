# ── Required ─────────────────────────────────────────────────────────────────

SOURCE_SHOP_DOMAIN=my-store.myshopify.com
SOURCE_CLIENT_ID=<CLIENT-ID>
SOURCE_CLIENT_SECRET=<CLIENT-SECRET>
SOURCE_ACCESS_TOKEN=<ACCESS-TOKEN>

DEST_SHOP_DOMAIN=my-store.myshopify.com
DEST_CLIENT_ID=<CLIENT-ID>
DEST_CLIENT_SECRET=<CLIENT-SECRET>
DEST_ACCESS_TOKEN=<ACCESS-TOKEN>

DJANGO_DATABASE_URL=<DB-CONNECTI0N-STRING>
DJANGO_MEDIA_URL=<AWS-MEDIA-URL>

# ── Optional (defaults shown) ────────────────────────────────────────────────

API_VERSION=2024-01
DATA_DIR=./data
LOG_LEVEL=INFO

REST_BUCKET_SIZE=40
REST_REFILL_RATE=2
GRAPHQL_MAX_COST=1000
GRAPHQL_RESTORE_RATE=50
GRAPHQL_COST_THRESHOLD=200
MAX_RETRIES=5

# External HTML template rendered into product body_html. Edit freely.
DESCRIPTION_TEMPLATE=./templates/product_description.html.j2

# Locale tag used by tr_str() to extract translated text from <fr>...</fr> blocks.
MEAL_LOCALE=fr

# ── Loop weekly-menu auto-fill (`autofill-menu` command) ─────────────────────
# Loop Admin API token. Scopes: read subscription contracts, read & write
# customers. The Storefront Bundle write API is a Loop beta that must be enabled
# on the account before --no-dry-run can write.
LOOP_ADMIN_TOKEN=O8iHnkmsEEDeRPM8tsGebXL8fEVEvXDMYV1g3ePcaBHI0AlIsdGwvJpHZ2liDzoC
LOOP_API_BASE_URL=https://api.loopsubscriptions.com
LOOP_API_VERSION=2023-10
# Shopify product tag marking this week's active menu.
ACTIVE_MENU_TAG=current-menu
